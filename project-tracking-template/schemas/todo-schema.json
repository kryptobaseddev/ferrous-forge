{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://project-tracking-template/schemas/todo-schema.json",
  "title": "Project TODO Schema",
  "description": "Schema for project task tracking and management",
  "type": "object",
  "required": ["version", "lastUpdated", "projectName", "currentPhase", "phases", "globalMetrics", "tags"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version following semantic versioning"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date",
      "description": "Date when TODO file was last modified"
    },
    "projectName": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the project this TODO tracks"
    },
    "projectVersion": {
      "type": "string",
      "description": "Current version of the project being developed"
    },
    "currentPhase": {
      "type": "string",
      "pattern": "^PHASE_\\d+$",
      "description": "Currently active development phase"
    },
    "phases": {
      "type": "object",
      "patternProperties": {
        "^PHASE_\\d+$": {
          "type": "object",
          "required": ["name", "status", "priority", "todos"],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "description": "Human-readable name for the phase"
            },
            "targetVersion": {
              "type": "string",
              "description": "Target version for phase completion"
            },
            "estimatedDays": {
              "type": "number",
              "minimum": 0,
              "description": "Estimated duration in days"
            },
            "status": {
              "type": "string",
              "enum": ["NOT_STARTED", "IN_PROGRESS", "COMPLETED", "BLOCKED", "CANCELLED"],
              "description": "Current status of the phase"
            },
            "priority": {
              "type": "string",
              "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"],
              "description": "Priority level of the phase"
            },
            "description": {
              "type": "string",
              "description": "Detailed description of phase goals and scope"
            },
            "todos": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/todo"
              }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "globalMetrics": {
      "type": "object",
      "required": ["totalTodos", "completedTodos", "inProgressTodos", "notStartedTodos"],
      "properties": {
        "totalTodos": {
          "type": "integer",
          "minimum": 0
        },
        "completedTodos": {
          "type": "integer",
          "minimum": 0
        },
        "inProgressTodos": {
          "type": "integer",
          "minimum": 0
        },
        "notStartedTodos": {
          "type": "integer",
          "minimum": 0
        },
        "blockedTodos": {
          "type": "integer",
          "minimum": 0
        },
        "estimatedTotalHours": {
          "type": "number",
          "minimum": 0
        },
        "actualHoursSpent": {
          "type": "number",
          "minimum": 0
        },
        "criticalItems": {
          "type": "integer",
          "minimum": 0
        },
        "highPriorityItems": {
          "type": "integer",
          "minimum": 0
        },
        "mediumPriorityItems": {
          "type": "integer",
          "minimum": 0
        },
        "lowPriorityItems": {
          "type": "integer",
          "minimum": 0
        },
        "overdueTodos": {
          "type": "integer",
          "minimum": 0
        },
        "completionPercentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "averageHoursPerTodo": {
          "type": "number",
          "minimum": 0
        },
        "currentPhaseProgress": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "tags": {
      "type": "object",
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^P\\d+-\\d+$"
          }
        }
      }
    },
    "teamMembers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "assignedTodos": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^P\\d+-\\d+$"
            }
          },
          "expertise": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "availability": {
            "type": "string",
            "enum": ["full-time", "part-time", "contractor", "consultant"]
          }
        }
      }
    },
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "targetDate": {
            "type": "string",
            "format": "date"
          },
          "requiredPhases": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^PHASE_\\d+$"
            }
          },
          "status": {
            "type": "string",
            "enum": ["NOT_STARTED", "IN_PROGRESS", "COMPLETED", "AT_RISK", "DELAYED"]
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "riskRegister": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "severity", "probability", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^RISK-\\d+$"
          },
          "category": {
            "type": "string",
            "enum": ["technical", "business", "resource", "external", "schedule"]
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "probability": {
            "type": "string",
            "enum": ["very_high", "high", "medium", "low", "very_low"]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "impact": {
            "type": "string"
          },
          "mitigation": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["identified", "analyzing", "mitigating", "monitoring", "closed"]
          },
          "relatedTodos": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^P\\d+-\\d+$"
            }
          }
        }
      }
    },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "version", "changes"],
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "version": {
            "type": "string"
          },
          "changes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "author": {
            "type": "string"
          }
        }
      }
    },
    "configuration": {
      "type": "object",
      "properties": {
        "defaultPriority": {
          "type": "string",
          "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]
        },
        "defaultEstimateHours": {
          "type": "number",
          "minimum": 0
        },
        "workingDaysPerWeek": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7
        },
        "workingHoursPerDay": {
          "type": "number",
          "minimum": 0,
          "maximum": 24
        },
        "sprintLengthDays": {
          "type": "integer",
          "minimum": 1
        },
        "bufferPercentage": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "riskFactorMultiplier": {
          "type": "number",
          "minimum": 1
        },
        "qualityGateRequirements": {
          "type": "object",
          "properties": {
            "testCoverage": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "codeReviewRequired": {
              "type": "boolean"
            },
            "documentationRequired": {
              "type": "boolean"
            },
            "securityScanRequired": {
              "type": "boolean"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "todo": {
      "type": "object",
      "required": ["id", "title", "status", "priority"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^P\\d+-\\d+$",
          "description": "Unique identifier in format P{phase}-{number}"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Brief descriptive title of the task"
        },
        "feature": {
          "type": "string",
          "description": "Feature category or component this task belongs to"
        },
        "status": {
          "type": "string",
          "enum": ["NOT_STARTED", "IN_PROGRESS", "IN_REVIEW", "COMPLETED", "BLOCKED", "CANCELLED"],
          "description": "Current status of the task"
        },
        "priority": {
          "type": "string",
          "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"],
          "description": "Priority level for task completion"
        },
        "estimatedHours": {
          "type": "number",
          "minimum": 0,
          "description": "Estimated effort in hours"
        },
        "actualHours": {
          "type": "number",
          "minimum": 0,
          "description": "Actual time spent on task"
        },
        "assignee": {
          "type": ["string", "null"],
          "description": "Team member assigned to this task"
        },
        "createdDate": {
          "type": "string",
          "format": "date",
          "description": "Date when task was created"
        },
        "dueDate": {
          "type": ["string", "null"],
          "format": "date",
          "description": "Target completion date"
        },
        "implementation": {
          "type": "object",
          "description": "Technical implementation details",
          "properties": {
            "description": {
              "type": "string"
            },
            "files": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "functions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "commands": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "tests": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "documentation": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "enhanceFiles": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "newFiles": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "integrations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "acceptanceCriteria": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Testable conditions that must be met for task completion"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Other tasks or external dependencies required"
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Identified risks that could impact task completion"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Additional context, decisions, or implementation notes"
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for categorization and filtering"
        }
      }
    }
  }
}