    echo
    print_colored $YELLOW "📝 SESSION MANAGEMENT:"
    print_colored $GREEN "  new-session               Create new session notes file"
    print_colored $GREEN "  current-session           Show current/latest session info"
    print_colored $GREEN "  sessions                  List all session files"
    echo
    print_colored $YELLOW "🚀 QUICK ACTIONS:"
    print_colored $GREEN "  quick-check               Fast validation + status overview"
    print_colored $GREEN "  daily-standup             Generate standup report for today"
    print_colored $GREEN "  week-summary              Generate weekly progress summary"
    print_colored $GREEN "  release-readiness         Check if ready for release"
    echo
    print_colored $YELLOW "⚙️  SETUP & CONFIGURATION:"
    print_colored $GREEN "  setup                     Interactive setup wizard for new projects"
    print_colored $GREEN "  init                      Initialize tracking in existing project"
    print_colored $GREEN "  config                    Show current configuration"
    print_colored $GREEN "  install-hooks             Install git hooks for validation"
    echo
    print_colored $YELLOW "ℹ️  INFORMATION:"
    print_colored $GREEN "  help                      Show this help message"
    print_colored $GREEN "  version                   Show version information"
    print_colored $GREEN "  examples                  Show usage examples"
    echo
    print_colored $BLUE "💡 Examples:"
    print_colored $WHITE "  ./project-tracker status                    # Quick status check"
    print_colored $WHITE "  ./project-tracker report html              # HTML report"
    print_colored $WHITE "  ./project-tracker dashboard                # Generate & open dashboard"
    print_colored $WHITE "  ./project-tracker new-session              # Start new work session"
    print_colored $WHITE "  ./project-tracker quick-check              # Fast health check"
    echo
    print_colored $PURPLE "🔗 For detailed script documentation: ./project-tracker help <command>"
