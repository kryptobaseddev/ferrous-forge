check_dependencies() {
    local missing_deps=()
    
    # Check for Python 3
    if ! command -v python3 &> /dev/null; then
        missing_deps+=("python3")
    fi
    
    # Check for required files
    if [[ ! -f "$SCRIPTS_DIR/validate-tracking.sh" ]]; then
        missing_deps+=("validate-tracking.sh")
    fi
    
    if [[ ! -f "$SCRIPTS_DIR/generate-report.py" ]]; then
        missing_deps+=("generate-report.py")
    fi
    
    if [[ ${#missing_deps[@]} -gt 0 ]]; then
        print_colored $RED "❌ Missing dependencies:"
        for dep in "${missing_deps[@]}"; do
            print_colored $RED "   - $dep"
        done
        echo
        print_colored $YELLOW "Please ensure all required scripts are in the scripts/ directory"
        exit 1
    fi
}

get_project_info() {
    local project_name="Unknown Project"
    local project_version="Unknown"
    local current_phase="Unknown"
    
    if [[ -f "TODO.json" ]]; then
        project_name=$(python3 -c "
import json
try:
    with open('TODO.json') as f:
        data = json.load(f)
        print(data.get('projectName', 'Unknown Project'))
except:
    print('Unknown Project')
" 2>/dev/null)
        
        project_version=$(python3 -c "
import json
try:
    with open('TODO.json') as f:
        data = json.load(f)
        print(data.get('projectVersion', 'Unknown'))
except:
    print('Unknown')
" 2>/dev/null)
        
        current_phase=$(python3 -c "
import json
try:
    with open('TODO.json') as f:
        data = json.load(f)
        print(data.get('currentPhase', 'Unknown'))
except:
    print('Unknown')
" 2>/dev/null)
    fi
    
    echo "$project_name|$project_version|$current_phase"
}

show_quick_status() {
    local info=$(get_project_info)
    local project_name=$(echo $info | cut -d'|' -f1)
    local project_version=$(echo $info | cut -d'|' -f2)
    local current_phase=$(echo $info | cut -d'|' -f3)
    
    print_header
    print_colored $WHITE "📊 QUICK STATUS - $project_name"
    echo
    print_colored $BLUE "Project Version: $project_version"
    print_colored $BLUE "Current Phase: $current_phase"
    echo
    
    if [[ -f "TODO.json" ]]; then
        python3 -c "
import json
try:
    with open('TODO.json') as f:
        data = json.load(f)
    metrics = data.get('globalMetrics', {})
    
    total = metrics.get('totalTodos', 0)
    completed = metrics.get('completedTodos', 0)
    in_progress = metrics.get('inProgressTodos', 0)
    blocked = metrics.get('blockedTodos', 0)
    
    completion_pct = (completed / total * 100) if total > 0 else 0
    
    print(f'📋 Tasks: {completed}/{total} completed ({completion_pct:.1f}%)')
    print(f'⚙️  In Progress: {in_progress}')
    if blocked > 0:
        print(f'🚫 Blocked: {blocked} ⚠️')
    
    critical = metrics.get('criticalItems', 0)
    high = metrics.get('highPriorityItems', 0)
    if critical > 0 or high > 0:
        print(f'🔥 Priority Items: {critical} critical, {high} high')
    
    overdue = metrics.get('overdueTodos', 0)
    if overdue > 0:
        print(f'⏰ Overdue: {overdue} tasks')
        
except Exception as e:
    print('❌ Unable to read project status')
" 2>/dev/null
    else
        print_colored $YELLOW "⚠️  TODO.json not found in current directory"
    fi
    echo
}

interactive_menu() {
    while true; do
        print_header
        local info=$(get_project_info)
        local project_name=$(echo $info | cut -d'|' -f1)
        print_colored $WHITE "🎯 Interactive Menu - $project_name"
        echo
        
        print_colored $YELLOW "What would you like to do?"
        echo
        print_colored $GREEN "  1) Quick status check"
        print_colored $GREEN "  2) Generate HTML dashboard" 
        print_colored $GREEN "  3) Create new session notes"
        print_colored $GREEN "  4) Validate tracking files"
        print_colored $GREEN "  5) Update metrics"
        print_colored $GREEN "  6) Generate weekly report"
        print_colored $GREEN "  7) Check release readiness"
        print_colored $GREEN "  8) Full health check"
        print_colored $RED   "  9) Exit"
        echo
        
        read -p "Enter your choice (1-9): " choice
        
        case $choice in
            1)
                show_quick_status
                read -p "Press Enter to continue..." 
                ;;
            2)
                echo
                print_colored $BLUE "🔄 Generating HTML dashboard..."
                python3 "$SCRIPTS_DIR/generate-report.py" --format=html --output=dashboard.html
                print_colored $GREEN "✅ Dashboard created: dashboard.html"
                
                # Try to open in browser
                if command -v xdg-open &> /dev/null; then
                    xdg-open dashboard.html
                elif command -v open &> /dev/null; then
                    open dashboard.html
                else
                    print_colored $YELLOW "💡 Open dashboard.html in your browser"
                fi
                read -p "Press Enter to continue..."
                ;;
            3)
                echo
                "$SCRIPTS_DIR/new-session.sh"
                read -p "Press Enter to continue..."
                ;;
            4)
                echo
                "$SCRIPTS_DIR/validate-tracking.sh"
                read -p "Press Enter to continue..."
                ;;
            5)
                echo
                python3 "$SCRIPTS_DIR/update-metrics.py" --verbose
                read -p "Press Enter to continue..."
                ;;
            6)
                echo
                print_colored $BLUE "📊 Generating weekly summary..."
                python3 "$SCRIPTS_DIR/generate-report.py" --format=markdown
                read -p "Press Enter to continue..."
                ;;
            7)
                echo
                check_release_readiness
                read -p "Press Enter to continue..."
                ;;
            8)
                echo
                run_full_health_check
                read -p "Press Enter to continue..."
                ;;
            9)
                print_colored $GREEN "👋 Goodbye!"
                exit 0
                ;;
            *)
                print_colored $RED "❌ Invalid choice. Please enter 1-9."
                sleep 1
                ;;
        esac
    done
}

run_full_health_check() {
    print_colored $BLUE "🔍 Running full health check..."
    echo
    
    # Run validation
    print_colored $YELLOW "Step 1: Validating files..."
    if "$SCRIPTS_DIR/validate-tracking.sh"; then
        print_colored $GREEN "✅ File validation passed"
    else
        print_colored $RED "❌ File validation failed"
        return 1
    fi
    
    echo
    
    # Update and check metrics
    print_colored $YELLOW "Step 2: Checking metrics..."
    if python3 "$SCRIPTS_DIR/update-metrics.py" --dry-run; then
        print_colored $GREEN "✅ Metrics are consistent"
    else
        print_colored $RED "❌ Metrics need updating"
        print_colored $BLUE "💡 Run: ./project-tracker update-metrics"
    fi
    
    echo
    
    # Check for common issues
    print_colored $YELLOW "Step 3: Checking for common issues..."
    
    # Check for overdue tasks
    if [[ -f "TODO.json" ]]; then
        local overdue=$(python3 -c "
import json
from datetime import datetime
try:
    with open('TODO.json') as f:
        data = json.load(f)
    overdue = 0
    for phase_key, phase in data.get('phases', {}).items():
        for todo in phase.get('todos', []):
            due_date = todo.get('dueDate')
            if due_date and todo.get('status') not in ['COMPLETED', 'CANCELLED']:
                try:
                    due = datetime.strptime(due_date, '%Y-%m-%d')
                    if due < datetime.now():
                        overdue += 1
                except:
                    pass
    print(overdue)
except:
    print(0)
" 2>/dev/null)
        
        if [[ $overdue -gt 0 ]]; then
            print_colored $YELLOW "⚠️  Found $overdue overdue tasks"
        else
            print_colored $GREEN "✅ No overdue tasks"
        fi
    fi
    
    # Check for blocked tasks
    local blocked=$(python3 -c "
import json
try:
    with open('TODO.json') as f:
        data = json.load(f)
    blocked = data.get('globalMetrics', {}).get('blockedTodos', 0)
    print(blocked)
except:
    print(0)
" 2>/dev/null)
    
    if [[ $blocked -gt 0 ]]; then
        print_colored $YELLOW "⚠️  Found $blocked blocked tasks"
    else
        print_colored $GREEN "✅ No blocked tasks"
    fi
    
    echo
    print_colored $GREEN "🎉 Health check complete!"
}

check_release_readiness() {
    print_colored $BLUE "🚀 Checking release readiness..."
    echo
    
    local ready=true
    
    # Check if current phase is complete
    if [[ -f "TODO.json" ]]; then
        local phase_incomplete=$(python3 -c "
import json
try:
    with open('TODO.json') as f:
        data = json.load(f)
    current_phase = data.get('currentPhase', '')
    if current_phase in data.get('phases', {}):
        phase_todos = data['phases'][current_phase].get('todos', [])
        incomplete = sum(1 for todo in phase_todos if todo.get('status') != 'COMPLETED')
        print(incomplete)
    else:
        print(0)
except:
    print(0)
" 2>/dev/null)
        
        if [[ $phase_incomplete -gt 0 ]]; then
            print_colored $YELLOW "⚠️  Current phase has $phase_incomplete incomplete tasks"
            ready=false
        else
            print_colored $GREEN "✅ Current phase is complete"
        fi
    fi
    
    # Check for blockers
    local blocked=$(python3 -c "
import json
try:
    with open('TODO.json') as f:
        data = json.load(f)
    blocked = data.get('globalMetrics', {}).get('blockedTodos', 0)
    print(blocked)
except:
    print(0)
" 2>/dev/null)
    
    if [[ $blocked -gt 0 ]]; then
        print_colored $RED "❌ Found $blocked blocked tasks - not ready for release"
        ready=false
    else
        print_colored $GREEN "✅ No blocked tasks"
    fi
    
    # Check for critical/high priority incomplete tasks
    local critical_incomplete=$(python3 -c "
import json
try:
    with open('TODO.json') as f:
        data = json.load(f)
    count = 0
    for phase_key, phase in data.get('phases', {}).items():
        for todo in phase.get('todos', []):
            if todo.get('status') != 'COMPLETED' and todo.get('priority') in ['CRITICAL', 'HIGH']:
                count += 1
    print(count)
except:
    print(0)
" 2>/dev/null)
    
    if [[ $critical_incomplete -gt 0 ]]; then
        print_colored $RED "❌ Found $critical_incomplete incomplete critical/high priority tasks"
        ready=false
    else
        print_colored $GREEN "✅ All critical/high priority tasks complete"
    fi
    
    echo
    if [[ $ready == true ]]; then
        print_colored $GREEN "🎉 Project appears ready for release!"
        print_colored $BLUE "💡 Consider running: ./project-tracker report html > release-report.html"
    else
        print_colored $YELLOW "⚠️  Project not ready for release - address issues above"
    fi
}

generate_daily_standup() {
    print_colored $BLUE "🌅 Generating daily standup report..."
    echo
    
    # Show current status
    show_quick_status
    
    # Show recent session
    local latest_session=$(ls sessions/SESSION_*_NOTES.md 2>/dev/null | sort -V | tail -1)
    if [[ -f "$latest_session" ]]; then
        print_colored $BLUE "📝 Latest session: $(basename "$latest_session")"
        echo
    fi
    
    # Generate focused report
    python3 "$SCRIPTS_DIR/generate-report.py" --format=text | head -30
}

# Main command processing
COMMAND="${1:-}"

# Check dependencies first
check_dependencies

case "$COMMAND" in
    "help"|"-h"|"--help")
        if [[ -n "$2" ]]; then
            # Show help for specific command
            case "$2" in
                "validate")
                    print_colored $WHITE "🔍 VALIDATE COMMAND"
                    echo
                    print_colored $BLUE "Purpose: Validate all project tracking files"
                    print_colored $BLUE "Usage:   ./project-tracker validate"
                    echo
                    print_colored $GREEN "What it checks:"
                    print_colored $GREEN "  • JSON syntax validity"
                    print_colored $GREEN "  • Schema compliance"  
                    print_colored $GREEN "  • Consistency between files"
                    print_colored $GREEN "  • Placeholder values"
                    print_colored $GREEN "  • Metrics accuracy"
                    ;;
                "report")
                    print_colored $WHITE "📊 REPORT COMMAND"
                    echo
                    print_colored $BLUE "Purpose: Generate comprehensive project reports"
                    print_colored $BLUE "Usage:   ./project-tracker report [format]"
                    echo
                    print_colored $GREEN "Available formats:"
                    print_colored $GREEN "  • text (default) - Console-friendly report"
                    print_colored $GREEN "  • markdown      - GitHub/documentation ready"
                    print_colored $GREEN "  • html          - Visual dashboard"
                    print_colored $GREEN "  • json          - API/integration ready"
                    ;;
                *)
                    print_colored $RED "❌ No detailed help available for: $2"
                    print_usage
                    ;;
            esac
        else
            print_usage
        fi
        ;;
    "version"|"-v"|"--version")
        print_colored $CYAN "Project Tracker v1.0.0"
        print_colored $BLUE "Universal project tracking system"
        ;;
    "examples")
        show_examples
        ;;
    "status")
        show_quick_status
        ;;
    "report")
        FORMAT="${2:-text}"
        OUTPUT="${3:-}"
        if [[ -n "$OUTPUT" ]]; then
            python3 "$SCRIPTS_DIR/generate-report.py" --format="$FORMAT" --output="$OUTPUT"
            print_colored $GREEN "✅ Report saved: $OUTPUT"
        else
            python3 "$SCRIPTS_DIR/generate-report.py" --format="$FORMAT"
        fi
        ;;
    "dashboard")
        print_colored $BLUE "🔄 Generating HTML dashboard..."
        python3 "$SCRIPTS_DIR/generate-report.py" --format=html --output=dashboard.html
        print_colored $GREEN "✅ Dashboard created: dashboard.html"
        
        # Try to open in browser
        if command -v xdg-open &> /dev/null; then
            xdg-open dashboard.html &
            print_colored $BLUE "🌐 Opening in default browser..."
        elif command -v open &> /dev/null; then
            open dashboard.html &
            print_colored $BLUE "🌐 Opening in default browser..."
        else
            print_colored $YELLOW "💡 Open dashboard.html in your browser to view"
        fi
        ;;
    "validate")
        "$SCRIPTS_DIR/validate-tracking.sh"
        ;;
    "update-metrics")
        python3 "$SCRIPTS_DIR/update-metrics.py" "${@:2}"
        ;;
    "new-session")
        "$SCRIPTS_DIR/new-session.sh"
        ;;
    "check")
        run_full_health_check
        ;;
    "quick-check")
        print_colored $BLUE "⚡ Running quick check..."
        echo
        "$SCRIPTS_DIR/validate-tracking.sh" && echo && show_quick_status
        ;;
    "daily-standup")
        generate_daily_standup
        ;;
    "week-summary")
        print_colored $BLUE "📅 Generating weekly summary..."
        python3 "$SCRIPTS_DIR/generate-report.py" --format=markdown
        ;;
    "release-readiness")
        check_release_readiness
        ;;
    "sessions")
        print_colored $BLUE "📝 Session files:"
        ls sessions/SESSION_*_NOTES.md 2>/dev/null | sort -V | while read file; do
            if [[ -f "$file" ]]; then
                local session_num=$(basename "$file" | sed 's/SESSION_\([0-9]*\)_NOTES.md/\1/')
                local date=$(grep "Date:" "$file" | head -1 | cut -d':' -f2- | xargs)
                print_colored $GREEN "  Session $session_num - $date"
            fi
        done
        ;;
    "current-session")
        local latest=$(ls sessions/SESSION_*_NOTES.md 2>/dev/null | sort -V | tail -1)
        if [[ -f "$latest" ]]; then
            print_colored $GREEN "📝 Latest session: $(basename "$latest")"
            head -10 "$latest"
        else
            print_colored $YELLOW "⚠️  No session files found"
        fi
        ;;
    "metrics")
        python3 "$SCRIPTS_DIR/generate-report.py" --format=text | grep -A 20 "TASK SUMMARY"
        ;;
    "config")
        print_colored $BLUE "⚙️  Current Configuration:"
        echo
        if [[ -f "TODO.json" ]]; then
            python3 -c "
import json
try:
    with open('TODO.json') as f:
        data = json.load(f)
    config = data.get('configuration', {})
    if config:
        for key, value in config.items():
            print(f'  {key}: {value}')
    else:
        print('  No configuration section found')
except:
    print('  Unable to read configuration')
"
        else
            print_colored $YELLOW "  TODO.json not found"
        fi
        ;;
    "setup"|"init")
        print_colored $YELLOW "🚧 Interactive setup not yet implemented"
        print_colored $BLUE "💡 For now, please follow the SETUP_GUIDE.md"
        ;;
    "install-hooks")
        print_colored $YELLOW "🚧 Git hooks installation not yet implemented"  
        print_colored $BLUE "💡 Add to .git/hooks/pre-commit:"
        print_colored $WHITE "   ./project-docs/scripts/validate-tracking.sh"
        ;;
    "fix")
        print_colored $BLUE "🔧 Auto-fixing common issues..."
        python3 "$SCRIPTS_DIR/update-metrics.py"
        print_colored $GREEN "✅ Metrics updated"
        ;;
    "")
        # No command provided - show interactive menu
        interactive_menu
        ;;
    *)
        print_colored $RED "❌ Unknown command: $COMMAND"
        echo
        print_usage
        exit 1
        ;;
esac